<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity TransactionIngestion.
    -->
    <changeSet id="20260707174831-1" author="jhipster">
        <createTable tableName="transaction_ingestion" remarks="One execution that imports or receives one or many transactions.">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ingestion_type" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="status" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="source_label" type="varchar(100)">
                <constraints nullable="true" />
            </column>
            <column name="started_at" type="${datetimeType}">
                <constraints nullable="false" />
            </column>
            <column name="completed_at" type="${datetimeType}">
                <constraints nullable="true" />
            </column>
            <column name="records_received" type="integer">
                <constraints nullable="false" />
            </column>
            <column name="records_created" type="integer">
                <constraints nullable="false" />
            </column>
            <column name="records_skipped" type="integer">
                <constraints nullable="false" />
            </column>
            <column name="records_rejected" type="integer">
                <constraints nullable="false" />
            </column>
            <column name="error_message" type="varchar(2000)">
                <constraints nullable="true" />
            </column>
            <column name="created_at" type="${datetimeType}">
                <constraints nullable="false" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
        <dropDefaultValue tableName="transaction_ingestion" columnName="started_at" columnDataType="${datetimeType}"/>
        <dropDefaultValue tableName="transaction_ingestion" columnName="completed_at" columnDataType="${datetimeType}"/>
        <dropDefaultValue tableName="transaction_ingestion" columnName="created_at" columnDataType="${datetimeType}"/>
    </changeSet>

    <changeSet id="20260707174831-1-relations" author="jhipster">

        <createTable tableName="rel_transaction_ingestion__accounts">
            <column name="accounts_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="transaction_ingestion_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey columnNames="transaction_ingestion_id, accounts_id" tableName="rel_transaction_ingestion__accounts"/>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->
</databaseChangeLog>
