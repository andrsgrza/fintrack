<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity TransactionRuleCondition.
    -->
    <changeSet id="20260707174827-1" author="jhipster">
        <createTable tableName="transaction_rule_condition" remarks="One condition inside a transaction rule.\n\nvalue and secondValue are stored as strings and interpreted according to\nfield and operator by the service layer.">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="field" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="operator" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="value" type="varchar(1000)">
                <constraints nullable="false" />
            </column>
            <column name="second_value" type="varchar(1000)">
                <constraints nullable="true" />
            </column>
            <column name="case_sensitive" type="boolean">
                <constraints nullable="false" />
            </column>
            <column name="position" type="integer">
                <constraints nullable="false" />
            </column>
            <column name="transaction_rule_id" type="bigint">
                <constraints nullable="false" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->
</databaseChangeLog>
