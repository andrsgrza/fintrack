<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity ApiAccessToken.
    -->
    <changeSet id="20260707174835-1" author="jhipster">
        <createTable tableName="api_access_token" remarks="A hashed API credential owned by a user and restricted to explicitly\nselected accounts.">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false" />
            </column>
            <column name="token_prefix" type="varchar(20)">
                <constraints nullable="false" />
            </column>
            <column name="token_hash" type="varchar(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="ux_api_access_token__token_hash" />
            </column>
            <column name="status" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="created_at" type="${datetimeType}">
                <constraints nullable="false" />
            </column>
            <column name="updated_at" type="${datetimeType}">
                <constraints nullable="false" />
            </column>
            <column name="last_used_at" type="${datetimeType}">
                <constraints nullable="true" />
            </column>
            <column name="expires_at" type="${datetimeType}">
                <constraints nullable="true" />
            </column>
            <column name="revoked_at" type="${datetimeType}">
                <constraints nullable="true" />
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
        <dropDefaultValue tableName="api_access_token" columnName="created_at" columnDataType="${datetimeType}"/>
        <dropDefaultValue tableName="api_access_token" columnName="updated_at" columnDataType="${datetimeType}"/>
        <dropDefaultValue tableName="api_access_token" columnName="last_used_at" columnDataType="${datetimeType}"/>
        <dropDefaultValue tableName="api_access_token" columnName="expires_at" columnDataType="${datetimeType}"/>
        <dropDefaultValue tableName="api_access_token" columnName="revoked_at" columnDataType="${datetimeType}"/>
    </changeSet>

    <changeSet id="20260707174835-1-relations" author="jhipster">

        <createTable tableName="rel_api_access_token__accounts">
            <column name="accounts_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="api_access_token_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey columnNames="api_access_token_id, accounts_id" tableName="rel_api_access_token__accounts"/>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->
</databaseChangeLog>
