                                 />

        <addForeignKeyConstraint baseColumnNames="accounts_id"
                                 baseTableName="rel_api_access_token__accounts"
                                 constraintName="fk_rel_api_access_token__accounts__accounts_id"
                                 referencedColumnNames="id"
                                 referencedTableName="financial_account"
                                 />
    </changeSet>
</databaseChangeLog>
